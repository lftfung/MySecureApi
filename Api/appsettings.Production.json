{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-production-db-host;Port=5432;Database=MyFinanceDb;Username=postgres;Password=use_environment_variable"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "use_environment_variable_or_key_vault",
    "Issuer": "MyFinanceApi",
    "Audience": "MyFinanceUsers"
  }
}